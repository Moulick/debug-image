{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    'abandonments:recommended',
    'customManagers:dockerfileVersions',
    'customManagers:githubActionsVersions',
    'group:allNonMajor',
    ':assignAndReview(Moulick)',
    ':automergeDisabled',
    ':automergeLinters',
  ],
  packageRules: [
    {
      schedule: [
        '* * 1,10,20,30 * *',
      ],
      matchPackageNames: [
        'aws/*{/,}**',
      ],
    },
  ],
}
